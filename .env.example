# =============================================================================
# Shezhen AI 后端 — 环境变量配置模板
# =============================================================================
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env
# =============================================================================

# ------------------------------ 数据库配置 ------------------------------
MYSQL_ROOT_PASSWORD=Shezhenapp&root163
MYSQL_DATABASE=shezhen_ai
MYSQL_USER=shezhen
MYSQL_PASSWORD=shezhen_pass

# ------------------------------ JWT 配置 ------------------------------
# ⚠️ 生产环境务必修改为高强度随机字符串！
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ------------------------------ AI 模型配置 ------------------------------
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=your-dashscope-api-key
AI_MODEL_NAME=deepseek-v3.2
AI_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_VISION_MODEL_NAME=qwen-vl-plus

# ------------------------------ 应用配置 ------------------------------
LOG_LEVEL=INFO
APP_ENV=production
